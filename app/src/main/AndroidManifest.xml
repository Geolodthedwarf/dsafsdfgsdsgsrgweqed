<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />

    <!-- Camera for barcode scanning -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera" android:required="false" />
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false" />

    <!-- Storage for backup/restore -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29"
        tools:ignore="ScopedStorage" />

    <!-- Foreground service for sync -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Required on API 34+ when foregroundServiceType="dataSync" is declared -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".LibreLibrariaApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LibreLibraria"
        android:usesCleartextTraffic="true"
        tools:targetApi="34">

        <!-- Splash Activity -->
        <activity
            android:name=".ui.activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.LibreLibraria">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Main Activity -->
        <activity
            android:name=".ui.activities.MainActivity"
            android:exported="false"
            android:theme="@style/Theme.LibreLibraria" />

        <!-- Intro Activity -->
        <activity
            android:name=".ui.activities.IntroActivity"
            android:exported="false"
            android:theme="@style/Theme.LibreLibraria" />

        <!-- Book Detail Activity -->
        <activity
            android:name=".ui.activities.BookDetailActivity"
            android:parentActivityName=".ui.activities.MainActivity"
            android:theme="@style/Theme.LibreLibraria" />

        <!-- Add/Edit Book Activity -->
        <activity
            android:name=".ui.activities.AddEditBookActivity"
            android:parentActivityName=".ui.activities.MainActivity"
            android:theme="@style/Theme.LibreLibraria"
            android:windowSoftInputMode="adjustResize" />

        <!-- Diary Activity -->
        <activity
            android:name=".ui.activities.DiaryActivity"
            android:parentActivityName=".ui.activities.MainActivity"
            android:theme="@style/Theme.LibreLibraria" />

        <!-- Settings Activity -->
        <activity
            android:name=".ui.activities.SettingsActivity"
            android:parentActivityName=".ui.activities.MainActivity"
            android:theme="@style/Theme.LibreLibraria" />

        <!-- Theme Editor Activity -->
        <activity
            android:name=".ui.activities.ThemeEditorActivity"
            android:parentActivityName=".ui.activities.SettingsActivity"
            android:theme="@style/Theme.LibreLibraria" />

        <!-- Advanced Settings Activity -->
        <activity
            android:name=".ui.activities.AdvancedSettingsActivity"
            android:parentActivityName=".ui.activities.SettingsActivity"
            android:theme="@style/Theme.LibreLibraria" />

        <!-- Statistics Activity -->
        <activity
            android:name=".ui.activities.StatisticsActivity"
            android:parentActivityName=".ui.activities.MainActivity"
            android:theme="@style/Theme.LibreLibraria" />

        <!-- Tags Activity -->
        <activity
            android:name=".ui.activities.TagsActivity"
            android:parentActivityName=".ui.activities.MainActivity"
            android:theme="@style/Theme.LibreLibraria" />

        <!-- Barcode Scanner Activity -->
        <activity
            android:name="com.journeyapps.barcodescanner.CaptureActivity"
            android:screenOrientation="fullSensor"
            tools:replace="android:screenOrientation" />

        <!-- Sync Service -->
        <service
            android:name=".service.SyncService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- Local Server Service -->
        <service
            android:name=".service.LocalServerService"
            android:enabled="true"
            android:exported="false" />

        <!-- Widget: Book Count -->
        <receiver android:name=".widget.BookCountWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_book_count_info" />
        </receiver>

        <!-- Widget: Currently Reading -->
        <receiver android:name=".widget.CurrentlyReadingWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_currently_reading_info" />
        </receiver>

        <!-- Widget: Reading Challenge -->
        <receiver android:name=".widget.ReadingChallengeWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_reading_challenge_info" />
        </receiver>

    </application>

</manifest>