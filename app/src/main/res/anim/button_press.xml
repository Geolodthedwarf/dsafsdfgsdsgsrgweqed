<?xml version="1.0" encoding="UTF-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <set android:duration="100">
            <scale android:fromXScale="0.95" android:fromYScale="0.95"
                android:toXScale="1.0" android:toYScale="1.0"
                android:pivotX="50%" android:pivotY="50%" />
        </set>
    </item>
    <item android:state_focused="true">
        <set android:duration="100">
            <scale android:fromXScale="0.98" android:fromYScale="0.98"
                android:toXScale="1.0" android:toYScale="1.0"
                android:pivotX="50%" android:pivotY="50%" />
        </set>
    </item>
    <item>
        <set android:duration="100">
            <scale android:fromXScale="1.0" android:fromYScale="1.0"
                android:toXScale="0.98" android:toYScale="0.98"
                android:pivotX="50%" android:pivotY="50%" />
        </set>
    </item>
</selector>